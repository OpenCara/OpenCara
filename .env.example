# Orchestrator
PORT=3030
PUBLIC_BASE_URL=https://example.com
DATABASE_URL=postgres://opencara:opencara@localhost:5433/opencara

# GitHub App credentials (register at github.com/organizations/<org>/settings/apps/new)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=/abs/path/to/opencara.private-key.pem
# Webhook secret configured on the GitHub App (used to verify webhook signatures)
GITHUB_WEBHOOK_SECRET=changeme

# Sessions (openssl rand -hex 32)
SESSION_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=ocara_sid
SESSION_TTL_DAYS=14

# Agent host
ORCHESTRATOR_URL=http://localhost:3030
AGENT_HOST_TOKEN=changeme
