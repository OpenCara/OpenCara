{
  "name": "@opencara/cli",
  "version": "0.0.0",
  "description": "OpenCara agent-host CLI: register a machine as an agent host and run dispatched agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenCara/OpenCara.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "opencara": "./dist/bin.js"
  },
  "main": "./dist/bin.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/bin.ts",
    "start": "node dist/bin.js",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@opencara/shared": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2"
  }
}
