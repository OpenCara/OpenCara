{
  "name": "@opencara/orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc -b",
    "test": "node --import tsx --test --test-reporter=spec src/agents/__tests__/*.test.ts src/db/__tests__/*.test.ts src/github/__tests__/*.test.ts src/flows/__tests__/*.test.ts src/routes/api/__tests__/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.3.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@opencara/flows": "workspace:*",
    "@opencara/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.16",
    "postgres": "^3.4.5",
    "ulid": "^3.0.2",
    "ws": "^8.20.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2"
  }
}
