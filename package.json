{
  "name": "opencara-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run --pool forks --fileParallelism=false --project @opencara/shared && vitest run --pool forks --fileParallelism=false --project @opencara/server && vitest run --pool forks --fileParallelism=false --project opencara",
    "lint": "eslint .",
    "typecheck": "tsc --build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^7.24.0"
    }
  }
}
